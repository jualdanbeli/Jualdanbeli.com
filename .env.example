# ============================================================
# jualdanbeli — Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# ============================================================

# --- Database ---
DB_PASSWORD=ganti_dengan_password_kuat_anda

# --- Keamanan Aplikasi ---
SESSION_SECRET=ganti_dengan_string_random_panjang_minimal_64_karakter

# --- Midtrans Payment Gateway ---
# Daftar di: https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false     # Ganti ke true saat go-live

# --- RajaOngkir Shipping API ---
# Daftar di: https://rajaongkir.com/akun/registrasi
RAJAONGKIR_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Resend Email Service ---
# Daftar di: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- URL Aplikasi (untuk email links) ---
APP_URL=https://yourdomain.com

# --- Object Storage (opsional, untuk upload gambar) ---
# Gunakan Google Cloud Storage atau layanan S3-compatible
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=/app/uploads
